# Airtable
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id

# Session — 32+ character random string
SESSION_SECRET=your_random_session_secret_32_chars_minimum

# Email notifications (Resend)
RESEND_API_KEY=your_resend_api_key
# Manager receives payment + gate pass notifications
MANAGER_EMAIL=manager@example.com
# Accountant email is stored in the DB settings table, not here

# Cron job auth — any strong random string
CRON_SECRET=your_cron_secret_random_string

# App
NEXT_PUBLIC_APP_NAME=WoodWings

# Turso (staging/Vercel only — NEVER set locally, local always uses SQLite file)
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token
