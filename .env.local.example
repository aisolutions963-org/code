# Airtable
AIRTABLE_API_KEY=your_airtable_pat_token
AIRTABLE_BASE_ID=your_base_id

# Session — 32+ character random string
SESSION_SECRET=your_32_char_random_secret_here

# Database — Turso (cloud SQLite) — https://turso.tech (free tier)
# For local dev without Turso, leave these unset (falls back to file:data/users.db)
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Email notifications (Resend — free tier: 3000 emails/month)
RESEND_API_KEY=your_resend_api_key
# Manager receives task-pending-review emails
MANAGER_EMAIL=manager@woodwings.ae

# App
NEXT_PUBLIC_APP_NAME=WoodWings
